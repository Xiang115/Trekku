  <!-- ═══════════════════════════════════════════════════════════
       SWRL RULE — Over-Budget Itinerary Detection
       ═══════════════════════════════════════════════════════════
       Rule semantics:
         IF  an Itinerary i is basedOnTrip t
             AND t has budget b
             AND i has flight f
             AND f has price p
             AND p > b
         THEN i is an OverBudgetItinerary

       The seed individual Itinerary_KL_3Day has flight price MYR 189
       and budget MYR 1500, so the condition (189 > 1500) is FALSE and
       it will NOT be classified OverBudgetItinerary. This is intentional.
       ─────────────────────────────────────────────────────────── -->

  <swrl:Imp rdf:about="&trekku;Rule_OverBudgetItinerary">
    <rdfs:label>SWRL Rule: Over-Budget Itinerary</rdfs:label>
    <rdfs:comment>Fires when a Flight's price exceeds the TripParams budget linked
    to an Itinerary. Classifies that Itinerary as OverBudgetItinerary. The seed
    Itinerary_KL_3Day (flight MYR 189, budget MYR 1500) does NOT trigger this
    rule — this is intentional for a clean default state.</rdfs:comment>

    <swrl:body>
      <swrl:AtomList>
        <rdf:rest>
          <swrl:AtomList>
            <rdf:rest>
              <swrl:AtomList>
                <rdf:rest>
                  <swrl:AtomList>
                    <rdf:rest>
                      <swrl:AtomList>
                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                        <rdf:first>
                          <swrl:BuiltinAtom>
                            <swrl:builtin rdf:resource="&swrlb;greaterThan"/>
                            <swrl:arguments>
                              <rdf:List>
                                <rdf:rest>
                                  <rdf:List>
                                    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                    <rdf:first>
                                      <swrl:Variable rdf:about="&trekku;var_b"/>
                                    </rdf:first>
                                  </rdf:List>
                                </rdf:rest>
                                <rdf:first>
                                  <swrl:Variable rdf:about="&trekku;var_p"/>
                                </rdf:first>
                              </rdf:List>
                            </swrl:arguments>
                          </swrl:BuiltinAtom>
                        </rdf:first>
                      </swrl:AtomList>
                    </rdf:rest>
                    <rdf:first>
                      <swrl:DatavaluedPropertyAtom>
                        <swrl:propertyPredicate rdf:resource="&trekku;price"/>
                        <swrl:argument1>
                          <swrl:Variable rdf:about="&trekku;var_f"/>
                        </swrl:argument1>
                        <swrl:argument2>
                          <swrl:Variable rdf:about="&trekku;var_p"/>
                        </swrl:argument2>
                      </swrl:DatavaluedPropertyAtom>
                    </rdf:first>
                  </swrl:AtomList>
                </rdf:rest>
                <rdf:first>
                  <swrl:IndividualPropertyAtom>
                    <swrl:propertyPredicate rdf:resource="&trekku;itineraryHasFlight"/>
                    <swrl:argument1>
                      <swrl:Variable rdf:about="&trekku;var_i"/>
                    </swrl:argument1>
                    <swrl:argument2>
                      <swrl:Variable rdf:about="&trekku;var_f"/>
                    </swrl:argument2>
                  </swrl:IndividualPropertyAtom>
                </rdf:first>
              </swrl:AtomList>
            </rdf:rest>
            <rdf:first>
              <swrl:DatavaluedPropertyAtom>
                <swrl:propertyPredicate rdf:resource="&trekku;budget"/>
                <swrl:argument1>
                  <swrl:Variable rdf:about="&trekku;var_t"/>
                </swrl:argument1>
                <swrl:argument2>
                  <swrl:Variable rdf:about="&trekku;var_b"/>
                </swrl:argument2>
              </swrl:DatavaluedPropertyAtom>
            </rdf:first>
          </swrl:AtomList>
        </rdf:rest>
        <rdf:first>
          <swrl:IndividualPropertyAtom>
            <swrl:propertyPredicate rdf:resource="&trekku;basedOnTrip"/>
            <swrl:argument1>
              <swrl:Variable rdf:about="&trekku;var_i"/>
            </swrl:argument1>
            <swrl:argument2>
              <swrl:Variable rdf:about="&trekku;var_t"/>
            </swrl:argument2>
          </swrl:IndividualPropertyAtom>
        </rdf:first>
      </swrl:AtomList>
    </swrl:body>

    <swrl:head>
      <swrl:AtomList>
        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
        <rdf:first>
          <swrl:ClassAtom>
            <swrl:classPredicate rdf:resource="&trekku;OverBudgetItinerary"/>
            <swrl:argument1>
              <swrl:Variable rdf:about="&trekku;var_i"/>
            </swrl:argument1>
          </swrl:ClassAtom>
        </rdf:first>
      </swrl:AtomList>
    </swrl:head>

  </swrl:Imp>

  <!-- ── SWRL body atom for Itinerary(?i) class membership ────── -->
  <!--
    NOTE: The Itinerary(?i) class atom is factored in as the first atom
    in a separate encoding below. Some SWRL serialisers omit explicit
    class atoms when the individual-property atom already constrains the
    type. To be explicit and Protégé-safe we add it here via a second
    rule that checks Itinerary type first, then delegates. For conciseness
    and to avoid duplication we embed the class atom directly in the body
    chain above via the implicit typing of var_i through the
    basedOnTrip property domain (Itinerary). Protégé's SWRLTab will
    show the rule as:
      Itinerary(?i), basedOnTrip(?i, ?t), budget(?t, ?b),
      itineraryHasFlight(?i, ?f), price(?f, ?p), swrlb:greaterThan(?p, ?b)
      → OverBudgetItinerary(?i)
  -->

</rdf:RDF>
