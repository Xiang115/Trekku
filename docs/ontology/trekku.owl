    as supplied by the user.</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;TripParams"/>
    <rdfs:range  rdf:resource="&xsd;string"/>
  </owl:DatatypeProperty>

  <!-- ── TacitFeedback properties ─────────────────────────────── -->

  <owl:DatatypeProperty rdf:about="&trekku;feedbackType">
