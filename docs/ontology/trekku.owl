<?xml version="1.0" encoding="UTF-8"?>

<!--
  Trekku Travel Knowledge Management System — OWL Ontology
  Ontology IRI : http://trekku.um.edu.my/ontology#
  Format       : RDF/XML (Protégé 5.x / HermiT 1.4+)
  Author       : Trekku Project, Universiti Malaya
  Date         : 2026-06-09

  SWRL Rule note
  ──────────────
  The single SWRL rule fires when a Flight's price exceeds the TripParams
  budget and classifies the linked Itinerary as OverBudgetItinerary.
  The seed Itinerary (Itinerary_KL_3Day) uses AirAsiaFlight_PEN_KUL whose
  price is MYR 189, well below its TripParams budget of MYR 1 500.
  It therefore will NOT be classified as OverBudgetItinerary under the
  reasoner — this is intentional so the default data is clean.
  To trigger the rule in Protégé, change the flight price to a value
  greater than the budget, or change hasMaxPrice on the TripParams
  individual, then run HermiT.

  Hotel tier classification (reasoner-inferred, NOT asserted):
  ─────────────────────────────────────────────────────────────
  HotelIndividual_Budget   hasMaxPrice 150.00  → classified BudgetHotel   (< 200)
  HotelIndividual_MidRange hasMaxPrice 350.00  → classified MidRangeHotel (≥ 200, < 500)
  HotelIndividual_Luxury   hasMaxPrice 820.00  → classified LuxuryHotel   (≥ 500)
-->

<!DOCTYPE rdf:RDF [
  <!ENTITY owl  "http://www.w3.org/2002/07/owl#">
  <!ENTITY rdf  "http://www.w3.org/1999/02/22-rdf-syntax-ns#">
  <!ENTITY rdfs "http://www.w3.org/2000/01/rdf-schema#">
  <!ENTITY xsd  "http://www.w3.org/2001/XMLSchema#">
  <!ENTITY swrl "http://www.w3.org/2003/11/swrl#">
  <!ENTITY swrlb "http://www.w3.org/2003/11/swrlb#">
  <!ENTITY trekku "http://trekku.um.edu.my/ontology#">
]>

<rdf:RDF
  xmlns:owl   ="http://www.w3.org/2002/07/owl#"
  xmlns:rdf   ="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
  xmlns:rdfs  ="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:xsd   ="http://www.w3.org/2001/XMLSchema#"
  xmlns:swrl  ="http://www.w3.org/2003/11/swrl#"
  xmlns:swrlb ="http://www.w3.org/2003/11/swrlb#"
  xmlns:trekku="http://trekku.um.edu.my/ontology#"
  xmlns       ="http://trekku.um.edu.my/ontology#"
  xml:base    ="http://trekku.um.edu.my/ontology">

  <!-- ═══════════════════════════════════════════════════════════
       ONTOLOGY HEADER
       ═══════════════════════════════════════════════════════════ -->
  <owl:Ontology rdf:about="http://trekku.um.edu.my/ontology">
    <rdfs:label>Trekku Travel Knowledge Management Ontology</rdfs:label>
    <rdfs:comment>OWL ontology for the Trekku AI-driven travel KMS. Mirrors the
    Firestore entity model (Hotel, Attraction, Flight, Itinerary, etc.) and adds
    reasoner-inferred hotel price tiers and a SWRL over-budget detection rule.
    Namespace: http://trekku.um.edu.my/ontology#  Prefix: trekku:</rdfs:comment>
    <owl:versionInfo>1.0.0 — 2026-06-09</owl:versionInfo>
  </owl:Ontology>


  <!-- ═══════════════════════════════════════════════════════════
       CLASS HIERARCHY — TBox
       ═══════════════════════════════════════════════════════════ -->

  <!-- ── TravelEntity (abstract superclass) ────────────────────── -->
  <owl:Class rdf:about="&trekku;TravelEntity">
    <rdfs:label>Travel Entity</rdfs:label>
    <rdfs:comment>Abstract superclass for all bookable or visitable travel assets
    managed by the Trekku knowledge base.</rdfs:comment>
  </owl:Class>

  <!-- ── Hotel ──────────────────────────────────────────────────── -->
  <owl:Class rdf:about="&trekku;Hotel">
    <rdfs:label>Hotel</rdfs:label>
    <rdfs:comment>A lodging property with nightly price range (MYR), rating, and
    amenities. Automatically classified into a price tier by the reasoner via the
    hasMaxPrice data property.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="&trekku;TravelEntity"/>
  </owl:Class>

  <!-- ── Attraction ─────────────────────────────────────────────── -->
  <owl:Class rdf:about="&trekku;Attraction">
    <rdfs:label>Attraction</rdfs:label>
    <rdfs:comment>A tourist point-of-interest (museum, landmark, natural site, etc.)
    captured from the Trekku knowledge base via Google Maps / SerpAPI.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="&trekku;TravelEntity"/>
  </owl:Class>

  <!-- ── Flight ─────────────────────────────────────────────────── -->
  <owl:Class rdf:about="&trekku;Flight">
    <rdfs:label>Flight</rdfs:label>
    <rdfs:comment>A commercial flight option captured from the Trekku knowledge base
    via Google Flights / SerpAPI. Prices are in MYR.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="&trekku;TravelEntity"/>
  </owl:Class>

  <!-- Hotel, Attraction, Flight are pairwise disjoint -->
  <owl:AllDisjointClasses>
    <owl:members rdf:parseType="Collection">
      <rdf:Description rdf:about="&trekku;Hotel"/>
      <rdf:Description rdf:about="&trekku;Attraction"/>
      <rdf:Description rdf:about="&trekku;Flight"/>
    </owl:members>
  </owl:AllDisjointClasses>

  <!-- ────────────────────────────────────────────────────────────
       DEFINED (Equivalent-Class) Hotel price-tier subclasses
       The three ranges are mutually exclusive and cover all prices:
         BudgetHotel   : hasMaxPrice < 200   (maxExclusive 200)
         MidRangeHotel : 200 ≤ hasMaxPrice < 500
         LuxuryHotel   : hasMaxPrice ≥ 500   (minInclusive 500)
       A Hotel individual asserted ONLY as Hotel with a hasMaxPrice value
       is automatically sorted into exactly one tier by HermiT.
       ──────────────────────────────────────────────────────────── -->

  <!-- ── BudgetHotel ≡ Hotel ⊓ (hasMaxPrice some xsd:decimal[maxExclusive 200]) -->
  <owl:Class rdf:about="&trekku;BudgetHotel">
    <rdfs:label>Budget Hotel</rdfs:label>
    <rdfs:comment>Hotels whose maximum nightly rate is less than MYR 200. Defined
    class: inferred by the reasoner from the hasMaxPrice value; do not assert
    BudgetHotel directly on individuals.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="&trekku;Hotel"/>
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="&trekku;Hotel"/>
          <owl:Restriction>
            <owl:onProperty rdf:resource="&trekku;hasMaxPrice"/>
            <owl:someValuesFrom>
              <rdfs:Datatype>
                <owl:onDatatype rdf:resource="&xsd;decimal"/>
                <owl:withRestrictions rdf:parseType="Collection">
                  <rdf:Description>
                    <xsd:maxExclusive rdf:datatype="&xsd;decimal">200</xsd:maxExclusive>
                  </rdf:Description>
                </owl:withRestrictions>
              </rdfs:Datatype>
            </owl:someValuesFrom>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>

  <!-- ── MidRangeHotel ≡ Hotel ⊓ (hasMaxPrice some xsd:decimal[≥200, <500]) -->
  <owl:Class rdf:about="&trekku;MidRangeHotel">
    <rdfs:label>Mid-Range Hotel</rdfs:label>
    <rdfs:comment>Hotels whose maximum nightly rate is between MYR 200 (inclusive)
    and MYR 500 (exclusive). Defined class: inferred by the reasoner from the
    hasMaxPrice value; do not assert MidRangeHotel directly on individuals.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="&trekku;Hotel"/>
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="&trekku;Hotel"/>
          <owl:Restriction>
            <owl:onProperty rdf:resource="&trekku;hasMaxPrice"/>
            <owl:someValuesFrom>
              <rdfs:Datatype>
                <owl:onDatatype rdf:resource="&xsd;decimal"/>
                <owl:withRestrictions rdf:parseType="Collection">
                  <rdf:Description>
                    <xsd:minInclusive rdf:datatype="&xsd;decimal">200</xsd:minInclusive>
                  </rdf:Description>
                  <rdf:Description>
                    <xsd:maxExclusive rdf:datatype="&xsd;decimal">500</xsd:maxExclusive>
                  </rdf:Description>
                </owl:withRestrictions>
              </rdfs:Datatype>
            </owl:someValuesFrom>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>

  <!-- ── LuxuryHotel ≡ Hotel ⊓ (hasMaxPrice some xsd:decimal[≥500]) -->
  <owl:Class rdf:about="&trekku;LuxuryHotel">
    <rdfs:label>Luxury Hotel</rdfs:label>
    <rdfs:comment>Hotels whose maximum nightly rate is MYR 500 or above. Defined
    class: inferred by the reasoner from the hasMaxPrice value; do not assert
    LuxuryHotel directly on individuals.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="&trekku;Hotel"/>
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="&trekku;Hotel"/>
          <owl:Restriction>
            <owl:onProperty rdf:resource="&trekku;hasMaxPrice"/>
            <owl:someValuesFrom>
              <rdfs:Datatype>
                <owl:onDatatype rdf:resource="&xsd;decimal"/>
                <owl:withRestrictions rdf:parseType="Collection">
                  <rdf:Description>
                    <xsd:minInclusive rdf:datatype="&xsd;decimal">500</xsd:minInclusive>
                  </rdf:Description>
                </owl:withRestrictions>
              </rdfs:Datatype>
            </owl:someValuesFrom>
          </owl:Restriction>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
  </owl:Class>

  <!-- ── Location ───────────────────────────────────────────────── -->
  <owl:Class rdf:about="&trekku;Location">
    <rdfs:label>Location</rdfs:label>
    <rdfs:comment>A geographic location (city/region) with coordinates and country.
    Used by TravelEntity individuals to express where a hotel, attraction, or
    flight origin is situated.</rdfs:comment>
  </owl:Class>

  <!-- ── Itinerary ──────────────────────────────────────────────── -->
  <owl:Class rdf:about="&trekku;Itinerary">
    <rdfs:label>Itinerary</rdfs:label>
    <rdfs:comment>An AI-generated trip itinerary produced by the Trekku agent for a
    given TripParams. Contains one or more ItineraryDay instances and an optional
    outbound Flight.</rdfs:comment>
  </owl:Class>

  <!-- ── ItineraryDay ───────────────────────────────────────────── -->
  <owl:Class rdf:about="&trekku;ItineraryDay">
    <rdfs:label>Itinerary Day</rdfs:label>
    <rdfs:comment>A single day within an Itinerary, linking a Hotel (overnight
    accommodation) and one or more Attractions (activities).</rdfs:comment>
  </owl:Class>

  <!-- ── TripParams ─────────────────────────────────────────────── -->
  <owl:Class rdf:about="&trekku;TripParams">
    <rdfs:label>Trip Parameters</rdfs:label>
    <rdfs:comment>The user-supplied parameters for a trip: budget (MYR), number of
    days, number of travellers, origin state, destination city, and travel date.
    Used by the SWRL over-budget rule.</rdfs:comment>
  </owl:Class>

  <!-- ── AgentSession ───────────────────────────────────────────── -->
  <owl:Class rdf:about="&trekku;AgentSession">
    <rdfs:label>Agent Session</rdfs:label>
    <rdfs:comment>A conversational session between a user and the Trekku AI agent.
    Tracks conversation history, collected TripParams, and the last itinerary
    generated in that session.</rdfs:comment>
  </owl:Class>

  <!-- ── TacitFeedback ──────────────────────────────────────────── -->
  <owl:Class rdf:about="&trekku;TacitFeedback">
    <rdfs:label>Tacit Feedback</rdfs:label>
    <rdfs:comment>Explicit or implicit feedback signal recorded after a user
    interacts with an Itinerary (rating, text comment, modification). The signal
    value ranges from -1.0 (very negative) to +1.0 (very positive).</rdfs:comment>
  </owl:Class>

  <!-- ── RatingSnapshot ─────────────────────────────────────────── -->
  <owl:Class rdf:about="&trekku;RatingSnapshot">
    <rdfs:label>Rating Snapshot</rdfs:label>
    <rdfs:comment>A point-in-time record of a TravelEntity's rating, review count,
    and minimum price, captured during scheduled knowledge-base refresh cycles to
    support trend analysis.</rdfs:comment>
  </owl:Class>

  <!-- ── OverBudgetItinerary (target class for SWRL rule) ──────── -->
  <owl:Class rdf:about="&trekku;OverBudgetItinerary">
    <rdfs:label>Over-Budget Itinerary</rdfs:label>
    <rdfs:comment>An Itinerary classified by the SWRL rule as over-budget: its
    linked Flight price exceeds the budget declared in its TripParams. The seed
    individual Itinerary_KL_3Day is intentionally NOT over-budget (flight MYR 189
    vs. budget MYR 1500).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="&trekku;Itinerary"/>
  </owl:Class>


  <!-- ═══════════════════════════════════════════════════════════
       OBJECT PROPERTIES
       ═══════════════════════════════════════════════════════════ -->

  <!-- hasLocation -->
  <owl:ObjectProperty rdf:about="&trekku;hasLocation">
    <rdfs:label>has Location</rdfs:label>
    <rdfs:comment>Links a TravelEntity to its geographic Location.</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;TravelEntity"/>
    <rdfs:range  rdf:resource="&trekku;Location"/>
    <owl:inverseOf rdf:resource="&trekku;isLocationOf"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="&trekku;isLocationOf">
    <rdfs:label>is Location Of</rdfs:label>
    <rdfs:comment>Inverse of hasLocation. Links a Location back to the TravelEntity
    or entities situated there.</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;Location"/>
    <rdfs:range  rdf:resource="&trekku;TravelEntity"/>
    <owl:inverseOf rdf:resource="&trekku;hasLocation"/>
  </owl:ObjectProperty>

  <!-- includesDay -->
  <owl:ObjectProperty rdf:about="&trekku;includesDay">
    <rdfs:label>includes Day</rdfs:label>
    <rdfs:comment>Links an Itinerary to each of its constituent ItineraryDay
    individuals.</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;Itinerary"/>
    <rdfs:range  rdf:resource="&trekku;ItineraryDay"/>
    <owl:inverseOf rdf:resource="&trekku;isDayOf"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="&trekku;isDayOf">
    <rdfs:label>is Day Of</rdfs:label>
    <rdfs:comment>Inverse of includesDay. Links an ItineraryDay back to its parent
    Itinerary.</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;ItineraryDay"/>
    <rdfs:range  rdf:resource="&trekku;Itinerary"/>
    <owl:inverseOf rdf:resource="&trekku;includesDay"/>
  </owl:ObjectProperty>

  <!-- dayHasHotel -->
  <owl:ObjectProperty rdf:about="&trekku;dayHasHotel">
    <rdfs:label>day Has Hotel</rdfs:label>
    <rdfs:comment>Links an ItineraryDay to the Hotel booked for that night.</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;ItineraryDay"/>
    <rdfs:range  rdf:resource="&trekku;Hotel"/>
  </owl:ObjectProperty>

  <!-- dayHasAttraction -->
  <owl:ObjectProperty rdf:about="&trekku;dayHasAttraction">
    <rdfs:label>day Has Attraction</rdfs:label>
    <rdfs:comment>Links an ItineraryDay to an Attraction visited on that day.</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;ItineraryDay"/>
    <rdfs:range  rdf:resource="&trekku;Attraction"/>
  </owl:ObjectProperty>

  <!-- itineraryHasFlight -->
  <owl:ObjectProperty rdf:about="&trekku;itineraryHasFlight">
    <rdfs:label>itinerary Has Flight</rdfs:label>
    <rdfs:comment>Links an Itinerary to its outbound Flight. Used by the SWRL
    over-budget rule to compare flight price against trip budget.</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;Itinerary"/>
    <rdfs:range  rdf:resource="&trekku;Flight"/>
  </owl:ObjectProperty>

  <!-- basedOnTrip -->
  <owl:ObjectProperty rdf:about="&trekku;basedOnTrip">
    <rdfs:label>based On Trip</rdfs:label>
    <rdfs:comment>Links an Itinerary to the TripParams that were used to generate
    it. Required by the SWRL over-budget rule.</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;Itinerary"/>
    <rdfs:range  rdf:resource="&trekku;TripParams"/>
  </owl:ObjectProperty>

  <!-- sessionProducedItinerary -->
  <owl:ObjectProperty rdf:about="&trekku;sessionProducedItinerary">
    <rdfs:label>session Produced Itinerary</rdfs:label>
    <rdfs:comment>Links an AgentSession to the Itinerary it generated for the
    user.</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;AgentSession"/>
    <rdfs:range  rdf:resource="&trekku;Itinerary"/>
  </owl:ObjectProperty>

  <!-- feedbackOn -->
  <owl:ObjectProperty rdf:about="&trekku;feedbackOn">
    <rdfs:label>feedback On</rdfs:label>
    <rdfs:comment>Links a TacitFeedback record to the TravelEntity (Hotel,
    Attraction, or Flight) it concerns.</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;TacitFeedback"/>
    <rdfs:range  rdf:resource="&trekku;TravelEntity"/>
  </owl:ObjectProperty>

  <!-- snapshotOf -->
  <owl:ObjectProperty rdf:about="&trekku;snapshotOf">
    <rdfs:label>snapshot Of</rdfs:label>
    <rdfs:comment>Links a RatingSnapshot to the TravelEntity whose rating and price
    it records at a point in time.</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;RatingSnapshot"/>
    <rdfs:range  rdf:resource="&trekku;TravelEntity"/>
  </owl:ObjectProperty>


  <!-- ═══════════════════════════════════════════════════════════
       DATA PROPERTIES
       ═══════════════════════════════════════════════════════════ -->

  <!-- ── TravelEntity common properties ──────────────────────── -->

  <owl:DatatypeProperty rdf:about="&trekku;hasName">
    <rdfs:label>has Name</rdfs:label>
    <rdfs:comment>Human-readable name of the TravelEntity (hotel name, attraction
    name, airline + flight number, etc.).</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;TravelEntity"/>
    <rdfs:range  rdf:resource="&xsd;string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="&trekku;hasSource">
    <rdfs:label>has Source</rdfs:label>
    <rdfs:comment>Data source identifier for this entity record, e.g.
    "serpapi_hotels", "serpapi_attractions", "serpapi_flights".</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;TravelEntity"/>
    <rdfs:range  rdf:resource="&xsd;string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="&trekku;lastUpdated">
    <rdfs:label>last Updated</rdfs:label>
    <rdfs:comment>ISO 8601 UTC timestamp of the last knowledge-base refresh for
    this entity.</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;TravelEntity"/>
    <rdfs:range  rdf:resource="&xsd;dateTime"/>
  </owl:DatatypeProperty>

  <!-- ── Hotel properties ─────────────────────────────────────── -->

  <owl:DatatypeProperty rdf:about="&trekku;hasMinPrice">
    <rdfs:label>has Min Price (MYR)</rdfs:label>
    <rdfs:comment>Lowest nightly rate for this hotel in Malaysian Ringgit (MYR).
    Used with hasMaxPrice to determine the price range.</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;Hotel"/>
    <rdfs:range  rdf:resource="&xsd;decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="&trekku;hasMaxPrice">
    <rdfs:label>has Max Price (MYR)</rdfs:label>
    <rdfs:comment>Highest nightly rate for this hotel in Malaysian Ringgit (MYR).
    This value drives the reasoner-inferred price-tier classification:
    &lt;200 → BudgetHotel; 200–499 → MidRangeHotel; ≥500 → LuxuryHotel.</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;Hotel"/>
    <rdfs:range  rdf:resource="&xsd;decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="&trekku;hasRating">
    <rdfs:label>has Rating</rdfs:label>
    <rdfs:comment>Overall user rating for the hotel, typically on a 0–5 scale as
    returned by the Google Hotels SerpAPI engine.</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;Hotel"/>
    <rdfs:range  rdf:resource="&xsd;decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="&trekku;hasAmenity">
    <rdfs:label>has Amenity</rdfs:label>
    <rdfs:comment>A single amenity offered by this hotel (e.g. "Free Wi-Fi",
    "Swimming Pool", "Breakfast included"). Multi-valued; assert multiple
    triples for multiple amenities.</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;Hotel"/>
    <rdfs:range  rdf:resource="&xsd;string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="&trekku;hasCategory">
    <rdfs:label>has Category</rdfs:label>
    <rdfs:comment>Denormalised tier label stored in the source data record
    ("budget", "mid-range", "luxury"). Note: the OWL tier classification is
    determined by hasMaxPrice, not by this string.</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;Hotel"/>
    <rdfs:range  rdf:resource="&xsd;string"/>
  </owl:DatatypeProperty>

  <!-- ── Attraction properties ────────────────────────────────── -->

  <owl:DatatypeProperty rdf:about="&trekku;poiCategory">
    <rdfs:label>POI Category</rdfs:label>
    <rdfs:comment>Type of point-of-interest as returned by the Google Maps engine,
    e.g. "Museum", "Religious site", "Natural feature".</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;Attraction"/>
    <rdfs:range  rdf:resource="&xsd;string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="&trekku;openingHours">
    <rdfs:label>opening Hours</rdfs:label>
    <rdfs:comment>Human-readable opening hours string for the attraction,
    e.g. "Daily 9 AM – 10 PM".</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;Attraction"/>
    <rdfs:range  rdf:resource="&xsd;string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="&trekku;estimatedDuration">
    <rdfs:label>estimated Duration</rdfs:label>
    <rdfs:comment>Recommended visiting duration for the attraction, e.g.
    "1–2 hours".</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;Attraction"/>
    <rdfs:range  rdf:resource="&xsd;string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="&trekku;popularityScore">
    <rdfs:label>popularity Score</rdfs:label>
    <rdfs:comment>Google Maps popularity / rating score for the attraction on a
    0–5 scale.</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;Attraction"/>
    <rdfs:range  rdf:resource="&xsd;decimal"/>
  </owl:DatatypeProperty>

  <!-- ── Flight properties ────────────────────────────────────── -->

  <owl:DatatypeProperty rdf:about="&trekku;airline">
    <rdfs:label>airline</rdfs:label>
    <rdfs:comment>Name of the airline operating the flight, e.g. "AirAsia",
    "Malaysia Airlines", "Batik Air".</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;Flight"/>
    <rdfs:range  rdf:resource="&xsd;string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="&trekku;originState">
    <rdfs:label>origin State</rdfs:label>
    <rdfs:comment>Malaysian state or city from which the flight departs, matching
    the TREKKU_SEED flight_origins list (e.g. "Penang", "Johor Bahru").</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;Flight"/>
    <rdfs:range  rdf:resource="&xsd;string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="&trekku;price">
    <rdfs:label>price (MYR)</rdfs:label>
    <rdfs:comment>Total fare for this flight option in Malaysian Ringgit (MYR) as
    returned by the Google Flights SerpAPI engine. Used by the SWRL over-budget
    detection rule.</rdfs:comment>
    <rdfs:domain rdf:resource="&trekku;Flight"/>
    <rdfs:range  rdf:resource="&xsd;decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="&trekku;durationMinutes">
    <rdfs:label>duration Minutes</rdfs:label>
